# ─── Golf Charity Platform — Backend Environment Variables ───
# Copy this file to .env and fill in your values

PORT=5000

# Supabase — create a NEW project at https://supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# JWT — generate a long random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_jwt_secret_here_minimum_32_chars

# Stripe — get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Frontend URL (for CORS and Stripe redirects)
FRONTEND_URL=http://localhost:5173

# NODE_ENV
NODE_ENV=development
